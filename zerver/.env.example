# app state
JWT_SECRET=1234-abcd-4567-efgh
DATABASE_URL=postgres://user:password@localhost/database_name
BIND_ADDRESS=127.0.0.1:3000
# cors config
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# rust
# RUST_LOG accepts a bare level ("info") or per-target directives
# (parsed by tracing_subscriber::EnvFilter). Examples:
#   RUST_LOG=info
#   RUST_LOG=info,sqlx=warn,zwipe=debug,zerver=debug
# Common silencers: sqlx=warn (query spam), tower_http=info, hyper=warn.
RUST_LOG=info,sqlx=warn,zwipe=debug,zerver=debug
RUST_BACKTRACE=0
# log directory (default: /var/log/zwipe — override locally e.g. /tmp/zwipe-logs)
LOG_DIR=/tmp/zwipe-logs
# email config
RESEND_API_KEY=1234
RESEND_EMAIL_FROM=support@zwipe.net
# client min-version gate (0.0.0 = open / allow everyone; flip to force updates)
MIN_CLIENT_VERSION=0.0.0
# recommander (live deck-aware synergy for 25+ card decks; cache is the fallback)
# all optional — these are the defaults; tighten the timeout to fall back faster,
# set RECOMMANDER_ENABLED=false to force the cached signal everywhere.
RECOMMANDER_BASE_URL=https://api.recommander.cards/public-release
RECOMMANDER_TIMEOUT_MS=1000
RECOMMANDER_ENABLED=true
