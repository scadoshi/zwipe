  "query": "INSERT INTO card_profiles (scryfall_data_id, is_token)\n             VALUES ($1, $2)\n             ON CONFLICT (scryfall_data_id)\n             DO UPDATE SET updated_at = NOW(), is_token = EXCLUDED.is_token\n             RETURNING scryfall_data_id, is_token, created_at, updated_at",
